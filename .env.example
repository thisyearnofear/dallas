# Dallas Buyers Club: Agent Alliance — Example Environment
#
# IMPORTANT (Vite):
# - Variables prefixed with VITE_ are exposed to the browser build.
# - Do NOT put secrets in VITE_ variables.

# -----------------------------------------------------------------------------
# Solana (runtime network selection)
# -----------------------------------------------------------------------------
# devnet | testnet | mainnet-beta
VITE_SOLANA_NETWORK=devnet

# Optional RPC override (otherwise defaults are used)
VITE_SOLANA_RPC_ENDPOINT=https://api.devnet.solana.com

# Program IDs (override per network as needed; devnet has defaults in src/config/solana.ts)
VITE_SOLANA_OPTIMIZATION_LOG_PROGRAM_ID=
VITE_DBC_MINT_ADDRESS=
VITE_TREASURY_PROGRAM_ID=
VITE_MEMBERSHIP_PROGRAM_ID=
VITE_DBC_TOKEN_PROGRAM_ID_DEVNET=

# -----------------------------------------------------------------------------
# Optional: Aleo dual-chain verification layer
# -----------------------------------------------------------------------------
VITE_ENABLE_ALEO=false
VITE_ALEO_NETWORK=testnet
VITE_ALEO_PROGRAM_ID=dbc_verifier.aleo
VITE_ALEO_RELAYER_URL=

# -----------------------------------------------------------------------------
# External services (server-side usage recommended)
# -----------------------------------------------------------------------------
EDENLAYER_API_KEY=your_edenlayer_api_key_here
EDENLAYER_API_URL=https://api.edenlayer.com

BAGS_API_KEY=your_bags_api_key_here
BAGS_PARTNER_CONFIG=your_bags_partner_config_key_here
VITE_BAGS_API_URL=https://public-api-v2.bags.fm/api/v1
VITE_BAGS_RATE_LIMIT=1000

# -----------------------------------------------------------------------------
# Demo / pilot toggles (optional)
# -----------------------------------------------------------------------------
DEMO_MODE=true
DEBUG_MODE=false
