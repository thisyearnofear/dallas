# ============================================
# Dallas Buyers Club: Agent Alliance — Environment
# ============================================

# --- Solana ---
# devnet | testnet | mainnet-beta
VITE_SOLANA_NETWORK=devnet
# Optional: override default RPC
# VITE_SOLANA_RPC_ENDPOINT=https://api.devnet.solana.com

# Program IDs (populated from config/solana.ts defaults for devnet)
# VITE_SOLANA_OPTIMIZATION_LOG_PROGRAM_ID=
# VITE_DBC_MINT_ADDRESS=
# VITE_TREASURY_PROGRAM_ID=
# VITE_MEMBERSHIP_PROGRAM_ID=
# VITE_DBC_TOKEN_PROGRAM_ID_DEVNET=

# --- Helius (optional, for enhanced indexing) ---
# VITE_HELIUS_API_KEY=
# VITE_HELIUS_WEBHOOK_URL=

# --- Privacy / ZK ---
# Set to 'true' to load real Noir prover (requires @noir-lang dependencies)
# VITE_ENABLE_REAL_ZK=false

# --- Aleo (optional dual-chain) ---
# VITE_ALEO_ENABLED=false

# --- Farcaster (optional social) ---
# VITE_FARCASTER_ENABLED=false
